# =========================================================
# Salin file ini menjadi .env lalu isi sesuai layanan masing-masing.
# JANGAN commit file .env (berisi kredensial asli) ke Git.
# =========================================================

# ---------- Flask ----------
FLASK_DEBUG=True
SECRET_KEY=ganti-dengan-secret-key-acak-yang-panjang

# ---------- TiDB Cloud (Database) ----------
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=portofolio
# Opsional, hanya jika perlu custom CA certificate untuk SSL
DB_CA_PATH=

# ---------- Cloudinary (Penyimpanan Gambar) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Resend (Pengiriman Email) ----------
RESEND_API_KEY=
# Default sandbox sender Resend, bisa diganti domain terverifikasi sendiri
RESEND_FROM_EMAIL=onboarding@resend.dev
# Email pemilik portofolio, penerima notifikasi dari form kontak
RESEND_TO_EMAIL=
